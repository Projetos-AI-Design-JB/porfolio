# ── Supabase / PostgreSQL ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas credenciais do Supabase.
# Dashboard Supabase → Project Settings → Database → Connection string → URI

DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJECT_REF].supabase.co:5432/postgres

# ── Opcional ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
